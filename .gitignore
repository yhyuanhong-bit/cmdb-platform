# ========================
# 项目专属规则
# ========================
cmdb-demo/dist/
cmdb-demo/.vite/
cmdb-demo/test-results/
cmdb-demo/playwright-report/
ingestion-engine/*.egg-info/
cmdb-core/bin/
cmdb-core/server
cmdb-core/cmdb-core
cmdb-core/cmdb-server

# ========================
# 环境变量文件（API密钥、数据库密码等）
# ========================
.env
.env.*
!.env.example

# ========================
# 密钥和证书
# ========================
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
id_rsa
id_ed25519

# ========================
# 云服务凭据
# ========================
.aws/credentials
.gcp/credentials.json
serviceAccountKey.json
terraform.tfvars
terraform.tfvars.json
*.tfstate
*.tfstate.backup

# ========================
# Docker
# ========================
docker-compose.override.yml
.docker/config.json

# ========================
# 数据库文件
# ========================
*.sql
!cmdb-core/db/**/*.sql
!ingestion-engine/db/**/*.sql
!ops/cutover/**/*.sql
*.sqlite
*.sqlite3
*.db
dump.rdb

# ========================
# API / Token / 凭据
# ========================
.npmrc
.pypirc
.netrc
.htpasswd

# ========================
# 应用框架敏感配置
# ========================
config/secrets.yml
config/master.key
wp-config.php
settings_local.py

# ========================
# Node.js
# ========================
node_modules/
package-lock.json
yarn.lock

# ========================
# Python
# ========================
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# ========================
# 日志
# ========================
*.log
logs/

# ========================
# 系统文件
# ========================
.DS_Store
Thumbs.db
desktop.ini

# ========================
# IDE / 编辑器
