{
  "dashboard": {
    "id": null,
    "uid": "cmdb-slo-overview",
    "title": "CMDB SLO Overview",
    "tags": ["cmdb", "slo"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "30s",
    "time": { "from": "now-6h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "type": "row",
        "title": "Headline SLOs (current vs target)",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
        "collapsed": false,
        "panels": []
      },
      {
        "id": 2,
        "title": "Availability — 30m (target 99.9%)",
        "description": "1 − (5xx / total) over the last 30 minutes. Pages on slo:http_errors fast burn (>14.4× of 0.001 over 1h+5m).",
        "type": "gauge",
        "gridPos": { "h": 7, "w": 12, "x": 0, "y": 1 },
        "targets": [
          {
            "expr": "sli:http_availability:ratio_30m",
            "refId": "A",
            "legendFormat": "availability"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0.99,
            "max": 1,
            "decimals": 4,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 0.999 },
                { "color": "green", "value": 0.9999 }
              ]
            }
          },
          "overrides": []
        },
        "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
      },
      {
        "id": 3,
        "title": "Latency (<1s) — 30m (target 99%)",
        "description": "Share of requests served under 1s in the last 30 minutes. Pages on slo:http_slow fast burn (>14.4× of 0.01 over 1h+5m).",
        "type": "gauge",
        "gridPos": { "h": 7, "w": 12, "x": 12, "y": 1 },
        "targets": [
          {
            "expr": "sli:http_latency:ratio_30m",
            "refId": "A",
            "legendFormat": "fast"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0.9,
            "max": 1,
            "decimals": 3,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 0.99 },
                { "color": "green", "value": 0.995 }
              ]
            }
          },
          "overrides": []
        },
        "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
      },
      {
        "id": 4,
        "type": "row",
        "title": "Burn rate (1h short window)",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 },
        "collapsed": false,
        "panels": []
      },
      {
        "id": 5,
        "title": "Availability burn — 1h",
        "description": "Current 1h error ratio expressed as multiples of the 30d budget burn (0.001). >14.4× over 1h consumes 2% of budget per hour.",
        "type": "stat",
        "gridPos": { "h": 6, "w": 12, "x": 0, "y": 9 },
        "targets": [
          {
            "expr": "slo:http_errors:ratio_1h / 0.001",
            "refId": "A",
            "legendFormat": "burn"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "orange", "value": 6 },
                { "color": "red", "value": 14.4 }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "graphMode": "area",
          "colorMode": "background",
          "reduceOptions": { "calcs": ["lastNotNull"] }
        }
      },
      {
        "id": 6,
        "title": "Latency burn — 1h",
        "description": "Current 1h slow ratio as multiples of the 30d budget burn (0.01).",
        "type": "stat",
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 9 },
        "targets": [
          {
            "expr": "slo:http_slow:ratio_1h / 0.01",
            "refId": "A",
            "legendFormat": "burn"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "orange", "value": 6 },
                { "color": "red", "value": 14.4 }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "graphMode": "area",
          "colorMode": "background",
          "reduceOptions": { "calcs": ["lastNotNull"] }
        }
      },
      {
        "id": 7,
        "type": "row",
        "title": "Bad-event ratio (multi-window)",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
        "collapsed": false,
        "panels": []
      },
      {
        "id": 8,
        "title": "HTTP 5xx ratio",
        "description": "slo:http_errors:ratio_5m / 30m / 1h / 6h. Persistent spread between short and long windows = noisy intermittent burst; spread that converges high = sustained outage.",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          { "expr": "slo:http_errors:ratio_5m", "legendFormat": "5m", "refId": "A" },
          { "expr": "slo:http_errors:ratio_30m", "legendFormat": "30m", "refId": "B" },
          { "expr": "slo:http_errors:ratio_1h", "legendFormat": "1h", "refId": "C" },
          { "expr": "slo:http_errors:ratio_6h", "legendFormat": "6h", "refId": "D" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percentunit", "decimals": 4 },
          "overrides": []
        }
      },
      {
        "id": 9,
        "title": "HTTP slow (>1s) ratio",
        "description": "slo:http_slow:ratio_5m / 30m / 1h / 6h. Same multi-window read as 5xx ratio.",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          { "expr": "slo:http_slow:ratio_5m", "legendFormat": "5m", "refId": "A" },
          { "expr": "slo:http_slow:ratio_30m", "legendFormat": "30m", "refId": "B" },
          { "expr": "slo:http_slow:ratio_1h", "legendFormat": "1h", "refId": "C" },
          { "expr": "slo:http_slow:ratio_6h", "legendFormat": "6h", "refId": "D" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percentunit", "decimals": 4 },
          "overrides": []
        }
      },
      {
        "id": 10,
        "type": "row",
        "title": "Sync apply (7d SLO target 99%)",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
        "collapsed": false,
        "panels": []
      },
      {
        "id": 11,
        "title": "Sync apply success — 30m (target 99%)",
        "description": "applied / (applied + failed + rejected) over the last 30 minutes. Skipped envelopes (version-gate no-ops) intentionally excluded. Returns no data until cmdb_sync_envelope_* counters are registered (OBS-SYNC).",
        "type": "gauge",
        "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
        "targets": [
          {
            "expr": "sli:sync_apply:ratio_30m",
            "refId": "A",
            "legendFormat": "applied"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0.9,
            "max": 1,
            "decimals": 3,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 0.99 },
                { "color": "green", "value": 0.995 }
              ]
            }
          },
          "overrides": []
        },
        "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
      },
      {
        "id": 12,
        "title": "Sync apply burn — 1h",
        "description": "Current 1h bad-outcome ratio as multiples of the 7d budget burn (0.01). >14.4× over 1h consumes 2% of the 7d budget per hour.",
        "type": "stat",
        "gridPos": { "h": 7, "w": 12, "x": 12, "y": 25 },
        "targets": [
          {
            "expr": "slo:sync_bad:ratio_1h / 0.01",
            "refId": "A",
            "legendFormat": "burn"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1 },
                { "color": "orange", "value": 6 },
                { "color": "red", "value": 14.4 }
              ]
            }
          },
          "overrides": []
        },
        "options": {
          "graphMode": "area",
          "colorMode": "background",
          "reduceOptions": { "calcs": ["lastNotNull"] }
        }
      },
      {
        "id": 13,
        "title": "Sync bad-outcome ratio (multi-window)",
        "description": "slo:sync_bad:ratio_5m / 30m / 1h / 6h. Failed + rejected envelopes / total. Skipped excluded.",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
        "targets": [
          { "expr": "slo:sync_bad:ratio_5m", "legendFormat": "5m", "refId": "A" },
          { "expr": "slo:sync_bad:ratio_30m", "legendFormat": "30m", "refId": "B" },
          { "expr": "slo:sync_bad:ratio_1h", "legendFormat": "1h", "refId": "C" },
          { "expr": "slo:sync_bad:ratio_6h", "legendFormat": "6h", "refId": "D" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percentunit", "decimals": 4 },
          "overrides": []
        }
      },
      {
        "id": 14,
        "type": "row",
        "title": "Active SLO alerts",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
        "collapsed": false,
        "panels": []
      },
      {
        "id": 15,
        "title": "Firing alerts (slo label)",
        "description": "ALERTS{slo!=\"\"} — fast/slow burn pages and tickets sourced from slo.yml. severity=page → on-call. severity=ticket → next business day.",
        "type": "table",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 41 },
        "targets": [
          {
            "expr": "ALERTS{slo!=\"\"}",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "fieldConfig": {
          "defaults": {},
          "overrides": []
        },
        "options": { "showHeader": true }
      }
    ]
  },
  "overwrite": true
}
