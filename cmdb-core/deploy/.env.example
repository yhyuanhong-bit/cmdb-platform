# ============================================================
# CMDB Platform — Environment Configuration
# Copy to .env and modify before deployment
# ============================================================

# --- Deployment Mode ---
DEPLOY_MODE=cloud          # cloud | edge
# TENANT_ID=              # Required for edge mode
# EDGE_NODE_ID=           # Required for edge mode

# --- Security (MUST change for production) ---
JWT_SECRET=change-me-to-a-64-char-random-string-for-production-use
DB_PASS=change-me-to-secure-password
REDIS_PASS=change-me-redis
# At-rest encryption key for integration adapter configs + webhook secrets.
# Must be exactly 64 hex chars (32 bytes, AES-256). Generate with:
#   go run -e 'package main; import ("fmt"; "github.com/cmdb-platform/cmdb-core/internal/platform/crypto"); func main(){fmt.Println(crypto.GenerateKeyHex())}'
# Startup fails if this is unset.
CMDB_SECRET_KEY=change-me-to-a-64-char-hex-encoded-aes-256-key

# --- Database ---
POSTGRES_DB=cmdb
POSTGRES_USER=cmdb
POSTGRES_PASSWORD=${DB_PASS}
DATABASE_URL=postgres://${POSTGRES_USER}:${DB_PASS}@postgres:5432/${POSTGRES_DB}?sslmode=disable

# --- Redis ---
REDIS_URL=redis://:${REDIS_PASS}@redis:6379/0

# --- NATS ---
NATS_URL=nats://nats:4222

# --- Sync ---
SYNC_ENABLED=true
SYNC_SNAPSHOT_BATCH_SIZE=500

# --- MCP (AI Integration) ---
MCP_ENABLED=true
MCP_PORT=3001
# MCP_API_KEY=            # Set for authenticated MCP access

# --- WebSocket ---
WS_ENABLED=true

# --- Observability ---
# OTEL_ENDPOINT=          # OpenTelemetry collector endpoint
LOG_LEVEL=info

# --- Scaling ---
CORE_REPLICAS=1
WORKER_REPLICAS=1

# --- Ports ---
FRONTEND_PORT=80
API_PORT=8080

# --- Private Registry (optional) ---
# REGISTRY=harbor.internal:5000/cmdb/
# VERSION=v1.2.0

# --- Carbon Emission ---
CARBON_EMISSION_FACTOR=0.0005
